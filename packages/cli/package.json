{
  "name": "@alerthq/cli",
  "version": "0.0.0",
  "type": "module",
  "description": "CLI for alerthq — sync, list, diff, tag, and export alert definitions",
  "bin": {
    "alerthq": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts",
    "test": "vitest run --passWithNoTests",
    "lint": "eslint src/"
  },
  "dependencies": {
    "commander": "^13.0.0"
  },
  "peerDependencies": {
    "@alerthq/core": "workspace:*"
  },
  "license": "MIT"
}
