{
  "name": "@alerthq/provider-azure-monitor",
  "version": "0.0.0",
  "type": "module",
  "description": "Azure Monitor alert provider for alerthq",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
