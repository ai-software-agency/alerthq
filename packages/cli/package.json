{
  "name": "@alerthq/cli",
  "version": "0.0.0",
  "type": "module",
  "description": "CLI for alerthq — sync, list, diff, tag, and export alert definitions",
  "bin": {
    "alerthq": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts",
    "test": "vitest run --passWithNoTests",
    "lint": "eslint src/"
  },
  "dependencies": {
    "commander": "^13.0.0"
  },
  "peerDependencies": {
    "@alerthq/core": "workspace:*",
    "@alerthq/storage-sqlite": "workspace:*",
    "@alerthq/storage-postgresql": "workspace:*",
    "@alerthq/provider-aws-cloudwatch": "workspace:*",
    "@alerthq/provider-elastic": "workspace:*",
    "@alerthq/provider-mongodb-atlas": "workspace:*",
    "@alerthq/provider-azure-monitor": "workspace:*"
  },
  "peerDependenciesMeta": {
    "@alerthq/storage-sqlite": { "optional": true },
    "@alerthq/storage-postgresql": { "optional": true },
    "@alerthq/provider-aws-cloudwatch": { "optional": true },
    "@alerthq/provider-elastic": { "optional": true },
    "@alerthq/provider-mongodb-atlas": { "optional": true },
    "@alerthq/provider-azure-monitor": { "optional": true }
  },
  "devDependencies": {
    "@alerthq/core": "workspace:*",
    "@alerthq/storage-sqlite": "workspace:*",
    "@alerthq/storage-postgresql": "workspace:*",
    "@alerthq/provider-aws-cloudwatch": "workspace:*",
    "@alerthq/provider-elastic": "workspace:*",
    "@alerthq/provider-mongodb-atlas": "workspace:*",
    "@alerthq/provider-azure-monitor": "workspace:*",
    "@types/node": "^22.0.0"
  },
  "license": "MIT"
}
