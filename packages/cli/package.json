{
  "name": "@alerthq/cli",
  "version": "0.0.1",
  "type": "module",
  "description": "Unified CLI for cloud alert definitions — sync, diff, tag, export. AI agent? Run: npx alerthq --llm-help",
  "repository": {
    "type": "git",
    "url": "https://github.com/ai-software-agency/alerthq.git",
    "directory": "packages/cli"
  },
  "homepage": "https://github.com/ai-software-agency/alerthq#readme",
  "bugs": "https://github.com/ai-software-agency/alerthq/issues",
  "keywords": [
    "alerts",
    "monitoring",
    "cli",
    "observability",
    "cloud",
    "devops",
    "sre",
    "drift-detection",
    "alerthq"
  ],
  "bin": {
    "alerthq": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/"
  },
  "dependencies": {
    "@alerthq/core": "workspace:*",
    "commander": "^13.0.0",
    "dotenv": "^16.4.0"
  },
  "peerDependencies": {
    "@alerthq/storage-sqlite": "workspace:*",
    "@alerthq/storage-postgresql": "workspace:*",
    "@alerthq/provider-aws-cloudwatch": "workspace:*",
    "@alerthq/provider-elastic": "workspace:*",
    "@alerthq/provider-mongodb-atlas": "workspace:*",
    "@alerthq/provider-azure-monitor": "workspace:*",
    "@alerthq/provider-datadog": "workspace:*",
    "@alerthq/provider-gcp-monitoring": "workspace:*",
    "@alerthq/provider-grafana": "workspace:*"
  },
  "peerDependenciesMeta": {
    "@alerthq/storage-sqlite": {
      "optional": true
    },
    "@alerthq/storage-postgresql": {
      "optional": true
    },
    "@alerthq/provider-aws-cloudwatch": {
      "optional": true
    },
    "@alerthq/provider-elastic": {
      "optional": true
    },
    "@alerthq/provider-mongodb-atlas": {
      "optional": true
    },
    "@alerthq/provider-azure-monitor": {
      "optional": true
    },
    "@alerthq/provider-datadog": {
      "optional": true
    },
    "@alerthq/provider-gcp-monitoring": {
      "optional": true
    },
    "@alerthq/provider-grafana": {
      "optional": true
    }
  },
  "devDependencies": {
    "@alerthq/storage-sqlite": "workspace:*",
    "@alerthq/storage-postgresql": "workspace:*",
    "@alerthq/provider-aws-cloudwatch": "workspace:*",
    "@alerthq/provider-elastic": "workspace:*",
    "@alerthq/provider-mongodb-atlas": "workspace:*",
    "@alerthq/provider-azure-monitor": "workspace:*",
    "@alerthq/provider-datadog": "workspace:*",
    "@alerthq/provider-gcp-monitoring": "workspace:*",
    "@alerthq/provider-grafana": "workspace:*",
    "@types/node": "^22.0.0"
  },
  "license": "MIT"
}
