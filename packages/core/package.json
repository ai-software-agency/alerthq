{
  "name": "@alerthq/core",
  "version": "0.0.1",
  "type": "module",
  "description": "Core library for alerthq — domain types, plugin interfaces, config/plugin loading, and core functions",
  "repository": {
    "type": "git",
    "url": "https://github.com/ai-software-agency/alerthq.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/ai-software-agency/alerthq#readme",
  "bugs": "https://github.com/ai-software-agency/alerthq/issues",
  "keywords": [
    "alerts",
    "monitoring",
    "observability",
    "cloud",
    "devops",
    "sre",
    "alerthq"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/"
  },
  "dependencies": {
    "dotenv": "^16.4.0",
    "uuid": "^11.0.0",
    "yaml": "^2.6.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/uuid": "^10.0.0"
  },
  "license": "MIT"
}
